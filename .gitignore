# Project-specific ignores
# Directory-specific gitignore files are in each subdirectory

# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp
.pnp.js
bun.lockb

# Build outputs
dist/
dist-ssr/
build/
*.local

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Cache and temporary files
.cache/
.temp/
.tmp/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# IDE and editor files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
*.sublime-project
*.sublime-workspace

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# System files
Thumbs.db 